{
  "expo": {
    "name": "FitRoam",
    "slug": "fitroam",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fitroam",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e0e0e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fitroam.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.fitroam.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e0e0e"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FitRoam needs your location to find gyms nearby."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6dcdd532-0a72-435f-9b0b-a95ae894cadd"
      }
    },
    "owner": "fitroam-team"
  }
}
